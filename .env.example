# =============================================================================
# .env.example — 三期「发布部署」环境变量模板
# 复制为 .env 并填入实际值后再启动 docker-compose
# =============================================================================

# ── 应用基础 ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── 数据存储路径（容器内路径） ──────────────────────────────────
DATABASE_PATH=/app/data/database.db
UPLOAD_DIR=/app/data/uploads

# ── 安全密钥（生产环境务必修改为高强度随机字符串！） ──────────
SESSION_SECRET=change-me-to-a-random-secret
JWT_SECRET=change-me-to-another-random-secret

# ── Redis（后续期启用） ──────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── 站点配置 ──────────────────────────────────────────────────────
SITE_NAME=Page Editor
SITE_URL=http://localhost
